# ─────────────────────────────────────────────────────────────────
# .env.example  –  실제 값을 채운 뒤 파일명을 .env 으로 바꾸세요.
# 이 파일은 Git에 커밋됩니다. 절대 실제 키를 여기에 입력하지 마세요.
# ─────────────────────────────────────────────────────────────────

# ── 한국투자증권 KIS API ──────────────────────────────────────────
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=여기에_앱키_입력
KIS_APP_SECRET=여기에_앱시크릿_입력
KIS_ACCOUNT_NUMBER=여기에_계좌번호_입력        # 예: 1234567801 (8자리+상품코드)
KIS_IS_MOCK=true                               # true=모의투자 / false=실전투자

# ── LLM 제공자 설정 ───────────────────────────────────────────────
# 사용할 LLM: openai | groq | ollama
LLM_PROVIDER=groq

## OpenAI (유료)
OPENAI_API_KEY=여기에_OpenAI_키_입력
OPENAI_MODEL=gpt-4o-mini

## Groq (무료 플랜 존재) – https://console.groq.com
GROQ_API_KEY=여기에_Groq_키_입력
GROQ_MODEL=llama-3.3-70b-versatile

## Ollama (로컬 무료) – ollama pull llama3.2 후 사용
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── 매매 기본 설정 ────────────────────────────────────────────────
# 종목코드:거래소 형식, 쉼표로 여러 종목 입력
# 거래소: KRX(한국) | NAS(나스닥) | NYS(뉴욕) | AMS(아멕스)
#         TSE(도쿄) | HKS(홍콩) | SHS(상해) | SZS(심천) | FRA(프랑크푸르트)
TARGET_TICKERS=005930:KRX,AAPL:NAS

ORDER_QUANTITY=1                               # 종목당 1회 주문 수량
STRATEGY_INTERVAL_SECONDS=3600                 # 전략 루프 주기 (초), 기본 1시간

# ── 기술적 분석 파라미터 ──────────────────────────────────────────
RSI_PERIOD=14                                  # RSI 계산 기간
RSI_OVERSOLD=30                                # 이 값 미만 → 매수 후보
RSI_OVERBOUGHT=70                              # 이 값 초과 → 매도 후보
BB_PERIOD=20                                   # 볼린저 밴드 기간
BB_STD=2.0                                     # 볼린저 밴드 표준편차 배수
LOOKBACK_DAYS=60                               # OHLCV 조회 기간 (거래일)

# ── 뉴스 감성 분석 파라미터 ───────────────────────────────────────
SENTIMENT_THRESHOLD=0.3                        # 감성 점수 임계값 (±0.3)
MAX_HEADLINES=15                               # LLM에 전달할 최대 헤드라인 수

# ── 트럼프 모니터 파라미터 ────────────────────────────────────────
TRUMP_BULL_THRESHOLD=0.35                      # 이 값 이상 → BULLISH
TRUMP_BEAR_THRESHOLD=-0.35                     # 이 값 이하 → BEARISH
TRUMP_POLL_INTERVAL=30                         # Truth Social 폴링 간격 (초)
