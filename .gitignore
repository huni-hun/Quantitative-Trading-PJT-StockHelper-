# ─────────────────────────────────────────────
# 민감 정보 (API 키, 계좌번호 등)
# ─────────────────────────────────────────────
.env
.env.*
!.env.example

# KIS 토큰 캐시 (자동 생성되는 액세스 토큰)
token_cache.json
kis_token*.json
access_token*.json

# ─────────────────────────────────────────────
# 전략 세팅 / 백테스트 결과
# ─────────────────────────────────────────────
config/local_*.py
config/personal_*.py
strategy_config.json
backtest_result*/
backtest_*.csv
backtest_*.json
result_*.csv
result_*.json

# ─────────────────────────────────────────────
# Python 캐시
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# ─────────────────────────────────────────────
# 로그 (디렉터리는 유지, 파일만 제외)
# ─────────────────────────────────────────────
/logs/*
!/logs/.gitkeep
*.log
*.log.*

# 거래내역 / 보유종목 (로컬 런타임 데이터)
logs/trades.json
logs/holdings.json
logs/notify_settings.json
logs/holdings.json

# ─────────────────────────────────────────────
# 가상환경
# ─────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─────────────────────────────────────────────
# 패키징 / 빌드
# ─────────────────────────────────────────────
dist/
build/
*.egg-info/
*.whl

# ─────────────────────────────────────────────
# IDE / 에디터
# ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────
# Jupyter Notebook
# ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─────────────────────────────────────────────
# 기타 임시 파일
# ─────────────────────────────────────────────
*.tmp
*.bak
*.orig
